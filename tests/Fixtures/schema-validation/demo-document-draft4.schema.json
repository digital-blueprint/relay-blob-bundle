{
    "id": "demo-document",
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "additionalProperties": false,
    "required": ["@type", "owner", "groupId", "status"],
    "properties": {
        "@type": {
            "$ref": "base/base-draft4.schema.json#/definitions/documentType"
        },
        "owner": {
            "$ref": "base/base-draft4.schema.json#/definitions/owner"
        },
        "groupId": {
            "$ref": "base/base-draft4.schema.json#/definitions/groupId"
        },
        "status": {
            "type": "string",
            "enum": ["draft", "final"]
        }
    }
}
