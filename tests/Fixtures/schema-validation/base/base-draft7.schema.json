{
    "$id": "base-draft7",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "documentType": {
            "const": "DemoDocumentV7"
        },
        "owner": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
                "id": {
                    "type": "string"
                }
            }
        },
        "groupId": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
    }
}
